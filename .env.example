# Iris LLM Configuration
# Copy to .env and fill in your actual values
# See CLAUDE.md §8 for complete documentation

# Anthropic (Claude models) - recommended
export ANTHROPIC_BASE_URL="https://api.anthropic.com"  # optional
export ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export CLAUDE_MODEL="claude-opus-4-6"
export CLAUDE_LITE_MODEL="claude-haiku-4-5-20251001"  # optional

# OpenAI (GPT models)
# export OPENAI_BASE_URL="https://api.openai.com/v1"  # optional
# export OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# export OPENAI_MODEL="gpt-4o"
# export OPENAI_LITE_MODEL="gpt-4o-mini"  # optional

# Google (Gemini models)
# export GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"  # optional
# export GEMINI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# export GEMINI_MODEL="gemini-2.0-flash-exp"
# export GEMINI_LITE_MODEL="gemini-2.0-flash-exp"  # optional

# DeepSeek
# export DEEPSEEK_BASE_URL="https://api.deepseek.com"  # optional
# export DEEPSEEK_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# export DEEPSEEK_MODEL="deepseek-chat"
# export DEEPSEEK_LITE_MODEL="deepseek-chat"  # optional

# Database (optional — no DB = ephemeral mode)
# export DATABASE_URL="postgres://user:pass@localhost/iris"

# Debug logging (writes to /tmp/iris.log)
# export RUST_LOG=info
